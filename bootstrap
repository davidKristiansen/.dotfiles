#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)

# ----- Safe XDG defaults (before mkdir) -----
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_BIN_HOME:=$HOME/.local/bin}"
: "${GNUPGHOME:=$HOME/.gnupg}"

# Ensure XDG dirs exist
mkdir -p "$XDG_CONFIG_HOME" \
         "$XDG_DATA_HOME" \
         "$XDG_STATE_HOME/zsh" \
         "$XDG_CACHE_HOME/zsh" \
         "$XDG_BIN_HOME" \
         "$GNUPGHOME" \
         "$XDG_CONFIG_HOME/systemd/user" \
         "$XDG_CONFIG_HOME/teams-for-linux" \
         "$HOME/.pi/agent/sessions" \
         "$HOME/.pi/context-mode/sessions"
chmod 700 "$GNUPGHOME"

echo Hold on to your bootstraps !

export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

(
  cd "${SCRIPT_DIR}"

  # Pull latest dotfiles before stowing
  git pull --rebase --quiet || true

  # Install stow.sh as a single self-contained file from the latest release.
  rm -f "$XDG_BIN_HOME/stow.sh"
  stow_tmp=$(mktemp)
  curl -fsSL "https://github.com/davetothek/stow.sh/releases/latest/download/stow.sh" -o "$stow_tmp"
  install -m 755 "$stow_tmp" "$XDG_BIN_HOME/stow.sh"
  rm -f "$stow_tmp"

  # First pass: stow ONLY the mise config so `mise install` below can read
  # conf.d. A full stow here would skip every ##exe.X config (their apps
  # aren't installed yet); the full stow happens after mise, once they exist.
  # Package `mise` is stripped by stow, so target is $XDG_CONFIG_HOME/mise →
  # links land at ~/.config/mise/conf.d/*.toml.
  stow.sh --dotfiles -f -d dot-config -t "$XDG_CONFIG_HOME/mise" mise
)

# dot-zshenv is sourced straight from the repo (not the stowed copy), so it
# doesn't need to be stowed in the first pass.
. ./dot-zshenv##shell.zsh

# ----- mise: dotfiles (incl. mise conf.d) are stowed now -----
if ! type mise &>/dev/null; then
  \curl https://mise.run | sh
else
  mise self-update --silent --yes
fi

for f in "$XDG_CONFIG_HOME"/mise/conf.d/*.toml; do
  mise trust "$f" &> /dev/null
done
mise plugin install neovim -q &> /dev/null

mise install --yes
mise upgrade --bump --quiet --yes --exclude uv

# ----- Full stow now that mise tools exist -----
# The first pass stowed only the mise config. This is the real stow of
# everything else; ##exe.X configs whose binaries mise just installed (on the
# shims dir already on PATH) now resolve and get linked. Idempotent.
(
  cd "${SCRIPT_DIR}"
  stow.sh --dotfiles -f
)

# vim: set ft=sh ts=2 sw=2:


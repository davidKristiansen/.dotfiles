#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)

# ----- Safe XDG defaults (before mkdir) -----
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_BIN_HOME:=$HOME/.local/bin}"
: "${GNUPGHOME:=$HOME/.gnupg}"

# Ensure XDG dirs exist
mkdir -p "$XDG_CONFIG_HOME" \
         "$XDG_DATA_HOME" \
         "$XDG_STATE_HOME/zsh" \
         "$XDG_CACHE_HOME/zsh" \
         "$XDG_BIN_HOME" \
         "$GNUPGHOME" \
         "$XDG_CONFIG_HOME/systemd/user" \
         "$XDG_CONFIG_HOME/teams-for-linux" \
         "$XDG_CONFIG_HOME/opencode" \
         "$HOME/.pi/agent/sessions" \
         "$HOME/.pi/context-mode/sessions"
chmod 700 "$GNUPGHOME"

echo Hold on to your bootstraps !

export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

(
  cd "${SCRIPT_DIR}"

  # Pull latest dotfiles before stowing
  git pull --rebase --quiet || true

  # Install stow.sh as a single self-contained file from the latest release.
  # This breaks the chicken-and-egg with mise: stowing no longer needs the
  # toolchain, so the mise setup can run afterwards (below). A download
  # failure aborts the bootstrap (set -e) — there's no stowing without it.
  # Drop any older hand-made symlink first — the release file is the source now.
  rm -f "$XDG_BIN_HOME/stow.sh"
  stow_tmp=$(mktemp)
  curl -fsSL "https://github.com/davetothek/stow.sh/releases/latest/download/stow.sh" -o "$stow_tmp"
  install -m 755 "$stow_tmp" "$XDG_BIN_HOME/stow.sh"
  rm -f "$stow_tmp"

  stow.sh -f
)

[[ -f "${HOME}/.zshenv" ]] && . "${HOME}/.zshenv" || true

# ----- mise: dotfiles (incl. mise conf.d) are stowed now -----
if ! type mise &>/dev/null; then
  \curl https://mise.run | sh
else
  mise self-update --silent --yes
fi

for f in "$XDG_CONFIG_HOME"/mise/conf.d/*.toml; do
  mise trust "$f" &> /dev/null
done
mise plugin install neovim -q &> /dev/null

mise install --yes
mise upgrade --bump --quiet --yes --exclude java --exclude uv

# vim: set ft=sh ts=2 sw=2:


# App scratchpads — each helper script launches the app on first use and
# toggles it afterwards.

# SpeedCrunch calculator
# speedcrunch.sh lives in dot-local/bin gated on ##exe.speedcrunch; re-enable the bind if speedcrunch gets installed.
for_window [app_id="org.speedcrunch.speedcrunch"] move scratchpad
for_window [class="SpeedCrunch" window_type="normal"] move scratchpad
# bindsym $mod+c exec $XDG_BIN_HOME/speedcrunch.sh

# Kuro (Microsoft To Do)
for_window [class="Kuro"] move scratchpad
bindsym $mod+m [class="Kuro"] scratchpad show

# 1Password
for_window [app_id="1Password"] move scratchpad
bindsym $mod+o exec $XDG_BIN_HOME/1password.sh

# Quake-style terminal — dedicated instance so the rule matches at map time
# and the window never enters the tiling layout; pre-launched at startup so
# the first toggle is instant
for_window [app_id="term.scratchpad"] move scratchpad
bindsym $mod+q exec $XDG_BIN_HOME/scratchpad.sh
exec $XDG_BIN_HOME/scratchpad.sh --prelaunch

# Spotify
for_window [class="Spotify"] move scratchpad
bindsym $mod+s exec $XDG_BIN_HOME/spotify.sh

# Enterprise LLM (browser PWA)
for_window [instance="crx__hijngppadlmpfgmhgphggfinhcbebdem"] move scratchpad
bindsym $mod+bracketleft [instance="crx__hijngppadlmpfgmhgphggfinhcbebdem"] scratchpad show, move position center, resize set 90 ppt 90 ppt

# LLM launcher (browser PWA)
for_window [instance="crx__cadlkienfkclaiaibeoongdcgmdikeeg"] move scratchpad
bindsym $mod+bracketright exec $XDG_BIN_HOME/llm.sh


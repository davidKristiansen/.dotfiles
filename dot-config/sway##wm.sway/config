set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term ghostty

# Default gap sizes (consumed by ux and the "gaps" mode in functions)
set $default_gaps_inner 7
set $default_gaps_outer 0

set $menu $term --class="term.launcher" -e $HOME/.local/bin/fzf-launcher
# set $menu vicinae toggle
set $menu_fallback 'bemenu-run \
  --ignorecase   \
  --fb "#1d2021" \
  --ff "#ebdbb2" \
  --nb "#1d2021" \
  --nf "#ebdbb2" \
  --tb "#1d2021" \
  --hb "#1d2021" \
  --tf "#fe8019" \
  --hf "#fabd2f" \
  --af "#ebdbb2" \
  --ab "#1d2021" \
  --prompt ">"   \
  --line-height 24'

set $lock '~/.local/bin/lock.sh -- -f'

set $screengrab slurp \
        | grim -g - - \
        | wl-copy

# Region screenshot into satty for annotation (mise shim — sway's exec PATH
# may not include shims). Copy button → clipboard, save button → ~/Pictures.
set $screenannotate slurp \
        | grim -g - - \
        | ~/.local/share/mise/shims/satty -f - \
          --copy-command wl-copy \
          --early-exit \
          --output-filename ~/Pictures/Screenshots/satty-%Y%m%d-%H%M%S.png

include colorscheme/gruvbox_dark_hard
include startup_applications
include input
include output
include functions
include keybindings
include ux
include scratchpad
include window_rules

# Distro drop-ins (e.g. systemd session activation). No-op if the dir is empty.
include /etc/sway/config.d/*

# vim: filetype=i3config

set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term ghostty

# Default gap sizes (consumed by ux and the "gaps" mode in functions)
set $default_gaps_inner 7
set $default_gaps_outer 0

set $menu swaymsg 'exec $term --class="term.launcher" -e $HOME/.local/bin/fzf-launcher'
# set $menu swaymsg 'exec vicinae toggle'
set $menu_fallback 'bemenu-run \
  --ignorecase   \
  --fb "#1d2021" \
  --ff "#ebdbb2" \
  --nb "#1d2021" \
  --nf "#ebdbb2" \
  --tb "#1d2021" \
  --hb "#1d2021" \
  --tf "#fe8019" \
  --hf "#fabd2f" \
  --nf "#ebdbb2" \
  --af "#ebdbb2" \
  --ab "#1d2021" \
  --prompt ">"   \
  --line-height 24'

set $lock '~/.local/bin/lock.sh -- -f'

set $screengrab slurp \
        | grim -g - - \
        | wl-copy

include colorscheme/gruvbox_dark_hard
include startup_applications
include input
include output
include functions
include keybindings
include ux
include scratchpad
include window_rules

# Distro drop-ins (e.g. systemd session activation). No-op if the dir is empty.
include /etc/sway/config.d/*

# vim: filetype=i3config

# Bars / output management
exec_always pkill kanshi || true && kanshi
exec_always pkill waybar || true && waybar

# Authentication agent + screencast portal
exec /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1
exec_always /usr/libexec/xdg-desktop-portal_wlr --replace

# Launcher daemon and idle/lock manager
exec_always 'vicinae server'
exec_always '${HOME}/.local/bin/idle.sh'

# Notification daemon (mako). exec, not exec_always: mako is dbus-activatable
# and reloads its own config via `makoctl reload`, so no respawn on sway reload.
exec mako

# Night light (toggle from waybar's gammastep module)
exec gammastep

# Auto-brightness (toggle from waybar's backlight-mode module)
exec_always ${HOME}/.local/bin/wluma
exec_always pkill -x wluma 2>/dev/null || true; sleep 0.3; exec "${XDG_BIN_HOME:-$HOME/.local/bin}/wluma"

# Export the session environment to D-Bus/systemd so portals and user
# services see WAYLAND_DISPLAY and XDG_CURRENT_DESKTOP.
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Desktop preferences
exec_always 'gsettings set org.gnome.desktop.interface color-scheme '"prefer-dark"'
exec_always 'xdg-settings set default-web-browser firefox.desktop'
exec_always 'gsettings set org.gnome.settings-daemon.plugins.xsettings overrides "{'Gtk/IMModule':<'fcitx'>}"'


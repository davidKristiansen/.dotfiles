# Session daemons are managed by systemd user units (see systemd/user in the
# dotfiles): waybar, kanshi, swayidle, gammastep, wluma, ghostty, mako, the
# polkit agent, and the portals. Export the session environment first, then
# pull up the target. Both lines are idempotent, so exec_always keeps
# reloads safe.
exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway
exec_always systemctl --user start sway-session.target

# Desktop preferences (idempotent one-shots).
exec gsettings set org.gnome.desktop.interface color-scheme prefer-dark
exec xdg-settings set default-web-browser firefox.desktop


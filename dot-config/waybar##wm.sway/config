{
  // ─────────────────────────────────────────────────────────────────────────
  //  Waybar — Sway · gruvbox dark hard · "islands"
  // ─────────────────────────────────────────────────────────────────────────
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 7,
  "margin-top": 7,
  "margin-left": 7,
  "margin-right": 7,
  "fixed-center": true,
  "reload_style_on_change": true,

  // Each top-level entry below renders as its own rounded "island" (see CSS).
  "modules-left": [
    "custom/power",
    "group/left"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "group/right",
    "tray"
  ],

  // ── Island groups ─────────────────────────────────────────────────────────
  "group/left": {
    "orientation": "horizontal",
    "modules": [
      "sway/workspaces",
      "sway/window",
      "sway/mode",
      "custom/media-prev",
      "custom/media-playpause",
      "custom/media-next",
      "custom/media"
    ]
  },
  "group/right": {
    "orientation": "horizontal",
    "modules": [
      "sway/language",
      "bluetooth",
      "network",
      "pulseaudio",
      "custom/backlight",
      "custom/backlight-mode",
      "custom/gammastep",
      "idle_inhibitor",
      "temperature",
      "disk",
      "cpu",
      "memory",
      "battery",
      "custom/mako"
    ]
  },

  // ── Launcher / power ──────────────────────────────────────────────────────
  "custom/power": {
    "format": "",
    "tooltip-format": "Power menu",
    "on-click": "$HOME/.config/waybar/power-menu.sh"
  },

  // ── Workspaces & mode ─────────────────────────────────────────────────────
  "sway/workspaces": {
    "disable-scroll": false,
    "persistent_workspaces": {
      "9": ["DP-5"]
    }
  },
  "sway/mode": {
    "format": "  {}",
    "max-length": 50
  },
  "sway/window": {
    "max-length": 40,
    "tooltip": true,
    "rewrite": {
      "(.*) — Mozilla Firefox": "$1",
      "(.*) - (.*)": "$1"
    }
  },

  // ── Media (generic MPRIS — Spotify, mpv, browsers, …) ─────────────────────
  "custom/media-prev": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/media-button.sh prev",
    "on-click": "playerctl previous",
    "tooltip": false
  },
  "custom/media-playpause": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/media-button.sh play",
    "on-click": "playerctl play-pause",
    "tooltip": false
  },
  "custom/media-next": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/media-button.sh next",
    "on-click": "playerctl next",
    "tooltip": false
  },
  "custom/media": {
    "format": "  {}",
    "return-type": "json",
    "max-length": 45,
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.sh",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  // ── Clock (with calendar tooltip) ─────────────────────────────────────────
  "clock": {
    "interval": 30,
    "format": "  {:%H:%M}",
    "format-alt": "  {:%a %d %b %Y}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "format": {
        "months":  "<span color='#fabd2f'><b>{}</b></span>",
        "days":    "<span color='#ebdbb2'>{}</span>",
        "weeks":   "<span color='#8ec07c'><b>W{}</b></span>",
        "weekdays":"<span color='#fe8019'><b>{}</b></span>",
        "today":   "<span color='#fb4934'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  // ── Keyboard layout ───────────────────────────────────────────────────────
  "sway/language": {
    "format": "  {short}",
    "tooltip-format": "{long}",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },

  // ── Bluetooth ─────────────────────────────────────────────────────────────
  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "󰂲",
    "format-off": "󰂲",
    "format-connected": "󰂱  {num_connections}",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{status}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} · {device_address}",
    "on-click": "swaymsg exec '$term --class=termfloat -e bluetoothctl'"
  },

  // ── Network ───────────────────────────────────────────────────────────────
  "network": {
    "interface": "wlp0s20f3",
    "format-wifi": "󰖩  {signalStrength}%",
    "format-ethernet": "󰈀  {ifname}",
    "format-disconnected": "󰖪  off",
    "tooltip-format": "{ifname} · {ipaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname} · {ipaddr}\n {bandwidthDownBits}    {bandwidthUpBits}",
    "tooltip-format-ethernet": "{ifname} · {ipaddr}\n {bandwidthDownBits}    {bandwidthUpBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "swaymsg exec '$term --class=termfloat -e nmtui'"
  },

  // ── Audio ─────────────────────────────────────────────────────────────────
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}  {volume}%",
    "format-muted": "  muted",
    "format-icons": {
      "headphone": "",
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["", "", ""]
    },
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%-",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  // ── Backlight (custom: polls backlight.sh so wluma's changes stay in sync,
  //    unlike waybar's native "backlight" module which can go stale) ─────────
  "custom/backlight": {
    "format": "{}",
    "return-type": "json",
    "interval": 2,
    "signal": 11,
    "exec": "$XDG_BIN_HOME/backlight.sh waybar",
    "on-scroll-up": "$XDG_BIN_HOME/backlight.sh up 1",
    "on-scroll-down": "$XDG_BIN_HOME/backlight.sh down 1"
  },

  // ── Backlight mode (auto/manual toggle for wluma) ─────────────────────────
  "custom/backlight-mode": {
    "format": "{}",
    "return-type": "json",
    "interval": 5,
    "signal": 10,
    "exec": "$XDG_BIN_HOME/backlight.sh mode",
    "on-click": "$XDG_BIN_HOME/backlight.sh toggle"
  },

  // ── Night light (gammastep — toggle on click) ─────────────────────────────
  "custom/gammastep": {
    "format": "{}",
    "return-type": "json",
    "interval": 30,
    "signal": 8,
    "exec": "$HOME/.config/waybar/gammastep.sh",
    "on-click": "$HOME/.config/waybar/gammastep.sh toggle && pkill -RTMIN+8 waybar"
  },

  // ── Do Not Disturb (mako) ─────────────────────────────────────────────────
  "custom/mako": {
    "format": " {} ",
    "return-type": "json",
    "interval": 30,
    "signal": 9,
    "exec": "$HOME/.config/waybar/mako-dnd.sh",
    "on-click": "$HOME/.config/waybar/mako-dnd.sh toggle && pkill -RTMIN+9 waybar"
  },

  // ── Idle inhibitor ────────────────────────────────────────────────────────
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    },
    "tooltip-format-activated": "Idle inhibitor: on",
    "tooltip-format-deactivated": "Idle inhibitor: off"
  },

  // ── Temperature (CPU package, stable coretemp path) ───────────────────────
  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 85,
    "interval": 5,
    "format": "{icon}  {temperatureC}°",
    "format-critical": "{icon}  {temperatureC}°",
    "format-icons": ["", "", "", "", ""],
    "tooltip-format": "CPU package: {temperatureC}°C",
    "on-click": "swaymsg exec '$term --class=__btop -e btop'"
  },

  // ── Disk ──────────────────────────────────────────────────────────────────
  "disk": {
    "interval": 60,
    "path": "/",
    "format": "  {percentage_used}%",
    "states": { "warning": 80, "critical": 95 },
    "tooltip-format": "{used} used of {total} on {path}  ({free} free)",
    "on-click": "nautilus"
  },

  // ── CPU ───────────────────────────────────────────────────────────────────
  "cpu": {
    "interval": 5,
    "format": "  {usage}%",
    "states": { "warning": 70, "critical": 90 },
    "tooltip": true,
    "on-click": "swaymsg exec '$term --class=__btop -e btop'"
  },

  // ── Memory ────────────────────────────────────────────────────────────────
  "memory": {
    "interval": 5,
    "format": "󰍛  {percentage}%",
    "states": { "warning": 75, "critical": 90 },
    "tooltip-format": "{used:0.1f} GiB / {total:0.1f} GiB  ({percentage}%)\nswap: {swapUsed:0.1f} / {swapTotal:0.1f} GiB",
    "on-click": "swaymsg exec '$term --class=__btop -e btop'"
  },

  // ── Battery ───────────────────────────────────────────────────────────────
  "battery": {
    "states": { "good": 80, "warning": 30, "critical": 15 },
    "format": "{icon}  {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-plugged": "  {capacity}%",
    "format-full": "  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["", "", "", "", ""],
    "tooltip-format": "{capacity}%  ·  {timeTo}\n{power:0.1f} W",
    "on-click": "swaymsg exec '$term --class=termfloat -e sudo powertop'"
  },

  // ── Tray ──────────────────────────────────────────────────────────────────
  "tray": {
    "icon-size": 15,
    "spacing": 8
  }
}

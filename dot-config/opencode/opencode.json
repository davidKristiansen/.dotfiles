{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": [
        "github-copilot",
        "google"
    ],
    "mcp": {
        "nvim-mcp": {
            "type": "local",
            "command": [
                "{env:HOME}/.local/share/mise/shims/nvim-mcp",
                "--connect",
                "auto"
            ],
            "enabled": true
        },
        "mempalace": {
            "type": "local",
            "command": [
                "bash",
                "{env:HOME}/.config/opencode/mempalace-mcp.sh"
            ],
            "enabled": true
        },
        "drawio": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@drawio/mcp"
            ],
            "enabled": true
        },
        "obsidian": {
            "type": "local",
            "command": [
                "npx",
                "@bitbonsai/mcpvault@latest",
                "{env:HOME}/.local/share/vault"
            ],
            "enabled": true
        },
        "obsidian-tasks": {
            "type": "local",
            "command": [
                "npx",
                "@jfim/obsidian-tasks-mcp",
                "{env:HOME}/.local/share/vault"
            ],
            "enabled": true
        },
        "mcpipe": {
            "type": "local",
            "command": [
                "{env:HOME}/Projects/mcp_toolbox/mcpipe/.venv/bin/mcpipe",
                "server"
            ],
            "enabled": true
        },
        "mcp-atlassian": {
            "type": "local",
            "command": [
                "uvx",
                "mcp-atlassian"
            ],
            "enabled": true,
            "environment": {
                "JIRA_URL": "{env:JIRA_URL}",
                "JIRA_PERSONAL_TOKEN": "{env:JIRA_PERSONAL_TOKEN}",
                "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
                "CONFLUENCE_PERSONAL_TOKEN": "{env:CONFLUENCE_PERSONAL_TOKEN}"
            }
        }
    },
    "permission": {
        "bash": {
            "git *": "allow",
            "python *": "allow",
            "python3 *": "allow",
            "pip *": "allow",
            "pip3 *": "allow",
            "uv *": "allow",
            "pytest *": "allow",
            "make *": "allow",
            "cmake *": "allow",
            "gcc *": "allow",
            "g++ *": "allow",
            "clang *": "allow",
            "ls *": "allow",
            "cat *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "find *": "allow",
            "fd *": "allow",
            "wc *": "allow",
            "diff *": "allow",
            "mkdir *": "allow",
            "cp *": "ask",
            "mv *": "ask",
            "rm *": "ask",
            "rm -rf *": "ask",
            "chmod *": "ask",
            "chown *": "deny",
            "sudo *": "ask",
            "curl *": "ask",
            "wget *": "ask",
            "ssh *": "ask",
            "scp *": "ask",
            "docker *": "ask",
            "systemctl *": "ask",
            "kill *": "ask",
            "pkill *": "ask",
            "dd *": "deny",
            "mkfs *": "deny",
            ":(){ :|:& };:": "deny"
        },
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow"
    }
}

lazy-lock.json
.zcompdump
zsh_plugins.zsh
.zsh_history
.luarc.json
.zcompcache

*.egg-info/  # Ignore Python egg-info directories
*.target.wants

# Machine-local secrets (never commit)
.secrets/

# Pi — secrets & ephemeral
.pi/agent/auth.json
.pi/agent/mcp-cache.json
.pi/agent/sessions/
.pi/context-mode/
# CocoIndex Code (ccc)
/.cocoindex_code/*
!/.cocoindex_code/global_settings.yml

# Claude Code — allowlist: ignore everything under .claude/, re-include only
# known-safe durable config. Keeps secrets (.credentials.json, session-env/,
# shell-snapshots/) and ephemeral state (projects/, sessions/, history) out.
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/output-styles/
!.claude/CLAUDE.md
# settings.local.json stays machine-local (also ignored via ~/.config/git/ignore)
.claude/settings.local.json
# Account/MCP/history blob at $HOME — never commit
/.claude.json
/.claude.json.backup*

# Git identity — user/machine-specific, kept out of the public repo.
# Copy the *.example templates and fill in locally; git silently skips
# missing include paths, so absence is harmless.
.config/git/priv.conf
.config/git/work.conf
.config/git/allowed_signers

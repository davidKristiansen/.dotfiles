#!/bin/sh
# xdg-desktop-portal-wlr dmenu chooser: a floating ghostty + fzf picker, no
# preview. With chooser_type=dmenu, xdpw (>=0.8) does the enumeration itself and
# pipes a newline-separated source list on stdin, e.g.
#   Monitor: DP-1
#   Window: <ext-foreign-toplevel-id> (firefox)
# We show that list in fzf and echo the chosen line back verbatim; xdpw matches
# it against what it sent. Printing nothing == user declined.
#
# Result handoff is file-based: fzf (running inside the ghostty PTY) writes the
# choice to $work/result and touches $work/done. We wait for that marker OR for
# ghostty to exit (covers a hard-kill), so the chooser never hangs.

set -u

# --- env bootstrap --------------------------------------------------------
# The portal runs us from a systemd user service whose PATH lacks the mise shims
# (fzf) and /opt/sway/bin (swaymsg), and which doesn't export SWAYSOCK.
: "${HOME:=$(getent passwd "$(id -u)" | cut -d: -f6)}"
export HOME
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:/opt/sway/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"
if [ -z "${SWAYSOCK:-}" ]; then
	for s in "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"/sway-ipc.*.sock; do
		[ -S "$s" ] && { SWAYSOCK="$s"; export SWAYSOCK; break; }
	done
fi
# --------------------------------------------------------------------------

work=$(mktemp -d "${XDG_RUNTIME_DIR:-/tmp}/screenshare.XXXXXX")
trap 'rm -rf "$work" 2>/dev/null' EXIT

# Capture the source list xdpw pipes to us; empty list == nothing to share.
cat > "$work/list"
[ -s "$work/list" ] || exit 0

# Paths handed to the inner fzf via env, so we avoid quoting them into -e.
export SCREENSHARE_LIST="$work/list"
export SCREENSHARE_RESULT="$work/result"
export SCREENSHARE_DONE="$work/done"

# Only ever one picker at a time: clear any leftover from an abandoned request.
swaymsg '[app_id="term.screenshare"] kill' >/dev/null 2>&1 || true

# fzf runs inside the new ghostty PTY: reads the list, writes the chosen line to
# $SCREENSHARE_RESULT, then touches $SCREENSHARE_DONE on any exit (Enter, Esc, or
# the window being killed) so we never block.
ghostty \
	--gtk-single-instance=false \
	--title="Select a screen or window to share" \
	--class="term.screenshare" \
	-e sh -c '
		fzf --reverse --border=rounded --margin=1 --padding=1 \
		    --prompt="Share ❯ " \
		    --header="↑↓ choose · Enter share · Esc cancel" \
		    < "$SCREENSHARE_LIST" > "$SCREENSHARE_RESULT"
		: > "$SCREENSHARE_DONE"
	' >/dev/null 2>&1 &
gpid=$!

# Wait for fzf to finish, or ghostty to vanish (hard-kill safety net).
while kill -0 "$gpid" 2>/dev/null && [ ! -e "$work/done" ]; do
	sleep 0.1
done

choice=$(cat "$work/result" 2>/dev/null || true)
[ -n "$choice" ] && printf '%s\n' "$choice"
exit 0

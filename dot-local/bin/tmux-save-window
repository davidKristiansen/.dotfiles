#!/usr/bin/env bash
# tmux-save-window: Save current window's pane layout, cwds, and commands
set -euo pipefail

SAVE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/windows"
mkdir -p "$SAVE_DIR"

# Prompt for a name (default: current window name)
current_name=$(tmux display-message -p '#W')
printf "Save as [%s]: " "$current_name"
read -r name
name="${name:-$current_name}"

# Sanitize: strip path separators
name="${name//\//-}"

# Rename the tmux window to match
tmux rename-window "$name"

# Capture window index and layout
window_index=$(tmux display-message -p '#{window_index}')
layout=$(tmux display-message -p '#{window_layout}')

# Capture per-pane state: index, cwd, command
panes=()
while IFS=$'\t' read -r idx cwd cmd; do
    panes+=("${idx}	${cwd}	${cmd}")
done < <(tmux list-panes -F "#{pane_index}	#{pane_current_path}	#{pane_current_command}")

# Write save file (keyed by name only)
savefile="$SAVE_DIR/$name"
{
    echo "window_index=$window_index"
    echo "layout=$layout"
    echo "panes=${#panes[@]}"
    for p in "${panes[@]}"; do
        echo "pane=$p"
    done
} > "$savefile"

tmux display-message "Window saved: $name"

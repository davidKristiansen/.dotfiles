{
  "mcpServers": {
    "mempalace": {
      "command": "bash",
      "args": ["-c", "$MEMPALACE_WRAPPER"],
      "env": {
        "MEMPALACE_WRAPPER": "${HOME}/.pi/agent/mempalace-mcp.sh"
      },
      "lifecycle": "eager",
      "idleTimeout": 10
    },
    "nvim-mcp": {
      "command": "nvim-mcp",
      "args": ["--connect", "auto"]
    },
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_PERSONAL_TOKEN": "${JIRA_PERSONAL_TOKEN}",
        "CONFLUENCE_URL": "${CONFLUENCE_URL}",
        "CONFLUENCE_PERSONAL_TOKEN": "${CONFLUENCE_PERSONAL_TOKEN}"
      }
    }
  }
}

#!/usr/bin/env bash
# tmux-todo-add: Quick-add a task to the obsidian vault inbox
set -euo pipefail

TODO_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/vault/32 Tasks/todo.md"

if [[ ! -f "$TODO_FILE" ]]; then
    echo "todo.md not found"
    exit 1
fi

printf "\033[1;33m󰄬 Add to inbox:\033[0m "
read -r task

if [[ -n "$task" ]]; then
    sed -i "/^## Inbox$/a - [ ] $task" "$TODO_FILE"
    printf "\033[1;32m✓\033[0m %s\n" "$task"
    sleep 0.4
fi

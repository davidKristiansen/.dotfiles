#!/bin/sh
# fzf preview helper for the screen-share picker.
#
# Argument is a CAPTURESPEC:
#   o:<output>            a monitor      -> grim -o <output>
#   w:<x,y wxh>|<app-id>  a window       -> grim -g "<geo>" if geo present,
#                                           else fall back to the app icon
#   anything else         -> text placeholder
#
# Thumbnails are captured with grim (cached) and rendered with chafa using the
# kitty graphics protocol, which ghostty supports.

set -u
spec="${1:-}"

cache="${SCREENSHARE_CACHE:-${XDG_RUNTIME_DIR:-/tmp}/screenshare-thumbs}"
mkdir -p "$cache"
cols="${FZF_PREVIEW_COLUMNS:-80}"
lines="${FZF_PREVIEW_LINES:-24}"

# Kitty graphics images survive a normal screen-clear, so the previous preview's
# image would otherwise stay on screen. Delete all images, then clear+home.
clear_preview() { printf '\033_Ga=d\033\\\033[2J\033[H'; }

render_image() {
	clear_preview
	chafa -f kitty --polite on --align center,center -s "${cols}x${lines}" "$1"
}

note() { clear_preview; printf '\n   %s\n' "$1"; }

# Resolve an application id to an icon file path on stdout, or fail.
resolve_icon() {
	_app="$1"
	[ -n "$_app" ] || return 1
	_icon=""
	for _d in "$HOME/.local/share/applications" /usr/local/share/applications \
	          /usr/share/applications /var/lib/snapd/desktop/applications \
	          /var/lib/flatpak/exports/share/applications \
	          "$HOME/.local/share/flatpak/exports/share/applications"; do
		if [ -f "$_d/$_app.desktop" ]; then
			_icon=$(grep -m1 '^Icon=' "$_d/$_app.desktop" | cut -d= -f2-)
			break
		fi
	done
	[ -n "$_icon" ] || _icon="$_app"

	# Absolute path in the desktop file (e.g. snap apps).
	case "$_icon" in
		/*) [ -f "$_icon" ] && { printf '%s\n' "$_icon"; return 0; } ;;
	esac

	for _e in png svg xpm; do
		[ -f "/usr/share/pixmaps/$_icon.$_e" ] && { printf '%s\n' "/usr/share/pixmaps/$_icon.$_e"; return 0; }
	done

	_themes="$HOME/.local/share/icons/Yaru-dark /usr/share/icons/Yaru-dark
	         /usr/share/icons/hicolor /usr/share/icons/Adwaita /usr/share/icons/Yaru"
	for _sz in 512x512 256x256 192x192 128x128 96x96 64x64 48x48 scalable 32x32; do
		for _t in $_themes; do
			for _e in png svg; do
				[ -f "$_t/$_sz/apps/$_icon.$_e" ] && { printf '%s\n' "$_t/$_sz/apps/$_icon.$_e"; return 0; }
			done
		done
	done

	_p=$(find /usr/share/icons /usr/share/pixmaps "$HOME/.local/share/icons" -type f \
	         \( -name "$_icon.png" -o -name "$_icon.svg" \) 2>/dev/null | head -1)
	[ -n "$_p" ] && { printf '%s\n' "$_p"; return 0; }
	return 1
}

# Capture a screen region/output into $1 (cached) using grim args $2..; echoes
# the path if it produced a non-empty file.
grab() {
	_out="$1"; shift
	[ -s "$_out" ] || grim "$@" "$_out" 2>/dev/null
	[ -s "$_out" ] && printf '%s\n' "$_out"
}

key=$(printf '%s' "$spec" | cksum | tr -d ' \t')
thumb="$cache/$key.png"

case "$spec" in
	o:*)
		if t=$(grab "$thumb" -o "${spec#o:}" -s 0.30); then
			render_image "$t"
		else
			note "(no live preview for this monitor)"
		fi
		;;
	w:*)
		rest="${spec#w:}"
		geo="${rest%%|*}"
		appid="${rest#*|}"
		if [ -n "$geo" ] && t=$(grab "$thumb" -g "$geo" -s 0.60); then
			render_image "$t"
		elif icon=$(resolve_icon "$appid"); then
			render_image "$icon"
		else
			note "(off-screen — no live preview)"
		fi
		;;
	*)
		note "(no preview available)"
		;;
esac

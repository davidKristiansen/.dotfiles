{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "github-copilot"
  ],
  "permission": {
    "bash": {
      "git *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "uv *": "allow",
      "pytest *": "allow",
      "make *": "allow",
      "cmake *": "allow",
      "gcc *": "allow",
      "g++ *": "allow",
      "clang *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "wc *": "allow",
      "diff *": "allow",
      "mkdir *": "allow",
      "cp *": "ask",
      "mv *": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "chmod *": "ask",
      "chown *": "deny",
      "sudo *": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "deny",
      "scp *": "deny",
      "docker *": "ask",
      "systemctl *": "deny",
      "kill *": "deny",
      "pkill *": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      ":(){ :|:& };:": "deny"
    },
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}

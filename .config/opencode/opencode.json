{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": [
        "github-copilot"
    ],
    "mcp": {
        "mempalace": {
            "type": "local",
            "command": [
                "bash", "{env:HOME}/.config/opencode/mempalace-mcp.sh"
            ],
            "enabled": true
        }
    },
    "permission": {
        "bash": {
            "git *": "allow",
            "python *": "allow",
            "python3 *": "allow",
            "pip *": "allow",
            "pip3 *": "allow",
            "uv *": "allow",
            "pytest *": "allow",
            "make *": "allow",
            "cmake *": "allow",
            "gcc *": "allow",
            "g++ *": "allow",
            "clang *": "allow",
            "ls *": "allow",
            "cat *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "find *": "allow",
            "fd *": "allow",
            "wc *": "allow",
            "diff *": "allow",
            "mkdir *": "allow",
            "cp *": "ask",
            "mv *": "ask",
            "rm *": "ask",
            "rm -rf *": "ask",
            "chmod *": "ask",
            "chown *": "deny",
            "sudo *": "deny",
            "curl *": "ask",
            "wget *": "ask",
            "ssh *": "deny",
            "scp *": "ask",
            "docker *": "ask",
            "systemctl *": "deny",
            "kill *": "deny",
            "pkill *": "deny",
            "dd *": "deny",
            "mkfs *": "deny",
            ":(){ :|:& };:": "deny"
        },
        "edit": "allow",
        "write": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow"
    }
}

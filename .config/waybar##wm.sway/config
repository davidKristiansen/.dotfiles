{
  "layer": "bottom",
  "height": 20,
  "spacing": 5,
  "modules-left": [
    "sway/workspaces",
    "custom/separator",
    "custom/spotify-prev",
    "custom/spotify-play-pause",
    "custom/spotify-next",
    "custom/separator",
    "custom/spotify",
    "sway/mode"
  ],
  "custom/spotify-prev": {
    "format": "´üł ",
    "exec": "$HOME/.config/waybar/spotify-prev.sh",
    "on-click": "playerctl --player=spotify previous",
    "exec-if": "pgrep spotify"
  },
  "custom/spotify-play-pause": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/spotify-play-pause.sh",
    "on-click": "playerctl --player=spotify play-pause",
    "exec-if": "pgrep spotify"
  },
  "custom/spotify-next": {
    "format": " ´üĹ",
    "exec": "$HOME/.config/waybar/spotify-next.sh",
    "on-click": "playerctl --player=spotify next",
    "exec-if": "pgrep spotify"
  },
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "sway/language",
    "custom/separator",
    "network",
    "custom/separator",
    "pulseaudio",
    "custom/separator",
    "backlight",
    "idle_inhibitor",
    // "custom/gammastep",
    "custom/separator",
    "battery",
    "custom/separator",
    "cpu",
    "custom/separator",
    "memory",
    "custom/separator",
    "tray"
  ],
  "tray": {
    "icon-size": 13,
    "spacing": 5
  },
  "sway/workspaces": {
    "persitant_workspaces": {
      "9": [
        "DP-5"
      ]
    }
  },
  "sway/mode": {
    "format": "| ´Ś╝ {}",
    "max-length": 50
  },
  "cpu": {
    "interval": 10,
    "format": "{load:3.1f}% ´őŤ",
    "max-length": 10,
    "on-click": "swaymsg 'exec $term --class __btop -e btop'"
  },
  "memory": {
    "format": "{}% ´âë",
    "on-click": "swaymsg 'exec $term --class __btop -e btop'"
  },
  "sway/window": {
    "max-length": 50
  },
  "sway/language": {
    "format": "{short} {variant}´äť",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },
  "custom/separator": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  },
  "custom/gammastep": {
    "format": "{}",
    "interval": 5,
    "on-update": "",
    "exec": "sleep 0.05; $HOME/.local/bin/gammastep.sh",
    "on-click": "$HOME/.local/bin/gammastep.sh toggle"
  },
  "custom/spotify": {
    "format": "´ć╝ {}",
    "return-type": "json",
    "max-length": 40,
    "exec": "$HOME/.config/waybar/mediaplayer.sh",
    "exec-if": "pgrep spotify"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon} ˇ▒Éő",
    "format-plugged": "{capacity}% {icon} ´çŽ",
    "format-alt": "{time} {icon}",
    //"format-full": "ţŽÁ {capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ]
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a, %d. %b  %H:%M}"
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "´ÇŽ",
    "on-click": "pavucontrol",
    "format-icons": [
      "´ÇŽ",
      "´Çž",
      "´ÇĘ"
    ]
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´Őö",
    "format-muted": "´ÇŽ",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´Çą",
      "headset": "´Çą",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": [
        "´ÇŽ",
        "´Çž",
        "´ÇĘ"
      ]
    },
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+ && ${XDG_BIN_HOME}/wp-vol",
    "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%- && ${XDG_BIN_HOME}/wp-vol",
    //"scroll-step": 1,
    "on-click-right": "pavucontrol",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": [
      "´ćů",
      "´äĹ"
    ],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    }
  },
  "network": {
    "interface": "wlp0s20f3",
    "format": "{ifname}",
    "format-wifi": "{essid} ({signalStrength}%) ´çź",
    "format-ethernet": "{ifname} ´âü",
    "format-disconnected": "",
    "tooltip-format": "{ifname}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ´çź",
    "tooltip-format-ethernet": "{ifname} ´âü",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    // "on-click": "$HOME/.local/bin/wifi-menu.sh 2>/dev/null"
    "on-click": "$term --class='termfloat' -e nmtui"
  },
  "custom/arrow1": {
    "format": "ţé▓"
  },
  "custom/arrow3": {
    "format": "ţé▓"
  },
  "custom/arrow0": {
    "format": "ţé│"
  },
  "custom/arrow4": {
    "format": "ţé▓"
  },
  "custom/arrow5": {
    "format": "ţé▓"
  },
  "custom/arrow6": {
    "format": "ţé░"
  },
  "custom/arrow7": {
    "format": "ţé░"
  },
  "custom/arrow8": {
    "format": "ţé░",
    "exec-if": "pgrep spotify"
  },
  "custom/arrow2": {
    "format": "ţé▓"
  }
}
